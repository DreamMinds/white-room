# Vorlage für die Server-Secrets.
# Auf dem Server nach "docker-compose.override.yml" kopieren und ausfüllen.
# Diese Datei (die .example) darf ins Repo; die echte override.yml ist gitignored.
#
# Seit die App eine native TWA ist, wurde die Traefik-Basic-Auth entfernt. Der
# Zugriff auf /api/* schützt jetzt SYNC_TOKEN (Bearer-Token, siehe sync/server.cjs).
# Der Token ist zugleich das Login-Passwort im App-Screen (AuthGate).
# Starken Token erzeugen z. B. mit:  openssl rand -base64 24
services:
  whiteroom-sync:
    environment:
      SYNC_TOKEN: "hier-einen-langen-zufaelligen-token-eintragen"
